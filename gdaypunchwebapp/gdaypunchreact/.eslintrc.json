{
    "env": {
        "browser": true,
        "es6": true
    },
    "extends": [
        "standard",
        "eslint:recommended",
        "plugin:import/warnings",
        "plugin:import/typescript",
        "plugin:react/recommended"
    ],
    "parserOptions": {
        "ecmaFeatures": {
            "jsx": true
        },
        "ecmaVersion": 2018,
        "sourceType": "module"
    },
    "plugins": [
        "react",
        "import"
    ],
    "rules": {
        "semi": "off",
        "indent": "off",
        "space-before-function-paren": "off",
        "quotes": "off",
        "generator-star-spacing": "off",
        "import/no-unresolved": [
            2, 
            { "caseSensitive": true }
         ]
    },
    "settings": {
        "import/resolver": {
          "webpack": {
            "config": "webpack.config.js"
          }
        }
    }
}