{
    "env": {
        "browser": true,
        "es6": true
    },
    "extends": [
        "plugin:react/recommended",
        "standard"
    ],
    "globals": {
        "Atomics": "readonly",
        "SharedArrayBuffer": "readonly"
    },
    "parserOptions": {
        "ecmaFeatures": {
            "jsx": true
        },
        "ecmaVersion": 2018,
        "sourceType": "module"
    },
    "plugins": [
        "react"
    ],
    "rules": {
        "semi": "off",
        "space-before-function-paren": "off",
        "quotes": "off",
        "import/no-unresolved": [
            2, 
            { "caseSensitive": true }
         ]
    },
    "settings": {
        "import/resolver": {
          "webpack": {
            "config": "webpack.config.js"
          }
        }
    }
}