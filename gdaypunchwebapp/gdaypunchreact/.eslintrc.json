{
    "env": {
        "browser": true,
        "es6": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:react/recommended"
    ],
    "globals": {
        "Atomics": "readonly",
        "SharedArrayBuffer": "readonly"
    },
    "parserOptions": {
        "ecmaFeatures": {
            "jsx": true
        },
        "ecmaVersion": 2018,
        "sourceType": "module"
    },
    "plugins": [
        "react"
    ],
    "rules": {
        "semi": "off",
        "indent": "off",
        "space-before-function-paren": "off",
        "quotes": "off",
        "generator-star-spacing": "off",
        "no-case-declarations": "off",
        "react/no-unused-state": "error",
        "import/no-unresolved": 0,
        "no-undef": "error",
        "react/prop-types": 0
    }
}