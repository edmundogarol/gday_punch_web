{
  "compilerOptions": {
    "target": "es6",
    "jsx": "react",
    "allowSyntheticDefaultImports": false,
    "baseUrl": "./",
    "paths": {
      "pages/*": ["src/pages/*"],
      "components/*": ["src/components/*"],
      "actions/*": ["src/actions/*"],
      "sagas/*": ["src/sagas/*"],
      "selectors/*": ["src/selectors/*"],
      "reducers/*": ["src/reducers/*"],
      "utils/*": ["src/utils/*"],
      "static/*": ["public/static/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}